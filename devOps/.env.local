# PostgreSQL (docker-compose postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=liquidflow_dev

# Backend – Prisma / app
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/liquidflow_dev

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# GitHub Actions: enable/disable continuous deployment (for reference)
ENABLE_CD=true
